# =============================================================================
# 环境变量模板 — 复制为 .env 并填入真实值
# cp .env.example .env   (Linux/Mac)
# copy .env.example .env  (Windows)
# =============================================================================

# ---- MySQL 数据库配置 ----
# docker-compose 中的 MySQL 容器会用这些变量初始化数据库
MYSQL_ROOT_PASSWORD=你的数据库密码
MYSQL_DATABASE=ai_assistant

# ---- 数据库连接（后端用，必填） ----
# 注意：db 是 docker-compose 中 MySQL 容器名，不要改成 localhost
DATABASE_URL=mysql+pymysql://root:${MYSQL_ROOT_PASSWORD}@db:3306/${MYSQL_DATABASE}

# ---- 阿里云 DashScope API（大模型调用，必填） ----
DASHSCOPE_API_KEY=sk-你的API密钥

# ---- JWT 密钥（必填） ----
# 生产环境请用高强度随机字符串替换，不要使用默认值！
# 生成密钥：openssl rand -hex 32
JWT_SECRET=你的JWT密钥
